# ------------------------------------------------------------------
# AlgoDémo Backend — variables d'environnement
# Copier ce fichier vers .env puis ajuster les valeurs :
#   Copy-Item .env.example .env
# ------------------------------------------------------------------

# Application
NODE_ENV=development
PORT=3000

# Base de données PostgreSQL (doit correspondre à docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=algodemo
DB_PASSWORD=algodemo
DB_NAME=algodemo

# Réservé aux futurs modules IA (synthèses fiche-pays, résumés de débats).
# Non utilisé pour l'instant — laisser vide.
ANTHROPIC_API_KEY=

# Authentification JWT (module Auth — Dev A)
# ⚠️ Valeurs de développement uniquement : générer des secrets forts et distincts en production.
JWT_ACCESS_SECRET=dev-access-secret-a-changer
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret-a-changer
JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------------------------------
# SMTP — envoi réel des codes OTP d'inscription (email)
# Laisser vide en dev = MODE DEV : les codes s'affichent dans les logs.
# OBLIGATOIRE avant toute utilisation avec de vrais utilisateurs.
#
# Option 1 — Gmail dédié au projet :
#   1. Créer un compte Gmail pour le projet (ex. algodemo.noreply@gmail.com)
#   2. Activer la validation en 2 étapes, puis générer un « mot de passe
#      d'application » : https://myaccount.google.com/apppasswords
#   3. SMTP_HOST=smtp.gmail.com · SMTP_PORT=587 · SMTP_SECURE=false
#      SMTP_USER=<adresse gmail> · SMTP_PASS=<mot de passe d'application>
#
# Option 2 — Brevo (gratuit jusqu'à 300 emails/jour) : https://www.brevo.com
#   SMTP_HOST=smtp-relay.brevo.com · SMTP_PORT=587
#   (identifiants fournis dans Brevo → SMTP & API)
# ------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ------------------------------------------------------------------
# LiveKit — vidéo en direct des débats (serveur auto-hébergé, docker-compose)
# Les clés DOIVENT correspondre à celles du conteneur livekit.
# En dev, les valeurs par défaut ci-dessous suffisent (mode --dev).
# En production : générer des clés fortes et héberger LiveKit en ligne (voir README).
# ------------------------------------------------------------------
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_a_changer_32chars_min_ok
LIVEKIT_PORT=7880
# IP annoncée aux navigateurs pour la vidéo (WebRTC).
# 127.0.0.1 = test sur le même PC ; l'IP LAN du PC pour des appareils distants.
LIVEKIT_NODE_IP=127.0.0.1

# ------------------------------------------------------------------
# Service IA — Mistral AI (synthèses fiche-pays, résumés de débats)
# Entreprise française, serveurs européens (cohérent RGPD, §9.3).
# Sans clé : le service utilise un texte de démonstration (stub).
#   1. Créer un compte : https://console.mistral.ai
#   2. Générer une clé API (palier gratuit « Experiment »)
#   3. Coller la clé ci-dessous
# ------------------------------------------------------------------
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# ------------------------------------------------------------------
# Stockage média S3-compatible (MinIO en dev, docker-compose).
# Vidéos/images des contenus, replays des débats.
# S3_PUBLIC_URL = base des URL publiques renvoyées aux clients :
#   en local même PC : http://localhost:9000
#   pour des téléphones du même Wi-Fi : http://<IP-du-PC>:9000
# En production : remplacer par le fournisseur S3 de l'organisation.
# ------------------------------------------------------------------
S3_ENDPOINT=localhost
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=algodemo
S3_SECRET_KEY=algodemo-secret
S3_BUCKET=algodemo-media
S3_PUBLIC_URL=http://localhost:9000

# ------------------------------------------------------------------
# Notifications push réelles (Firebase Cloud Messaging) — optionnel.
# Sans ce chemin, les push sont journalisés (mode dev), le reste marche.
#   1. console.firebase.google.com → créer un projet (gratuit)
#   2. Paramètres → Comptes de service → Générer une clé privée (JSON)
#   3. Enregistrer le fichier hors du repo et mettre son chemin ici
# ------------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_PATH=
